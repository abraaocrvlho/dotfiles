[colors]
background     = #292D3E
background-alt = #444
foreground     = #fff
foreground-alt = #555
primary        = #ffb52a
secondary      = #e60053
alert          = #bd2c40

;Palenight Colors
palenight_red     = #F07178
palenight_green   = #C3E88D
palenight_yellow  = #FFCB6B
palenight_blue    = #82AAFF
palenight_violet  = #C792EA
palenight_cyan    = #89DDFF
palenight_beige   = #D0D0D0

[bar/bar1]
monitor = ${env:monitor1}
width = 100%
height = 24
radius = 0.0
fixed-center = false

background = ${colors.background}
foreground = ${colors.foreground}

line-size = 0
line-color = #f00

border-size-bottom = 0
border-color = #7BC2DF

padding-left = 0
padding-right = 2

module-margin-left = 0
module-margin-right = 2

font-0 = fixed:pixelsize=10;1
font-1 = unifont:fontformat=truetype:size=8:antialias=false;0
font-2 = siji:pixelsize=10;1
font-3 = FantasqueSansMonoNerdFont:style=Regular:pixelsize=10;1
font-4 = IcoMoonFree:style=Regular:pixelsize=10;1
font-5 = i3fonticon:style=Regular:pixelsize=10;1
font-6 = MaterialIcons:style=Regular:pixelsize=11.5;3
font-7 = IonIcons:style=Medium:pixelsize=10;1
font-8 = NotoSansDisplayNF:style=Regular:pixelsize=11;2

modules-left = bspwm
modules-center =
modules-right = xbacklight pulseaudio wlan date time battery powermenu

cursor-click = pointer
cursor-scroll = ns-resize

separator = "|  "
padding = 2

;BAR 2

[bar/bar2]
monitor = ${env:monitor2}
width = 100%
height = 24
radius = 0.0
fixed-center = false

background = ${colors.background}
foreground = ${colors.foreground}

line-size = 0
line-color = #f00

border-size-bottom = 0
border-color = #7BC2DF

padding-left = 0
padding-right = 2

module-margin-left = 0
module-margin-right = 2

font-0 = fixed:pixelsize=10;1
font-1 = unifont:fontformat=truetype:size=8:antialias=false;0
font-2 = siji:pixelsize=10;1
font-3 = FantasqueSansMonoNerdFont:style=Regular:pixelsize=10;1
font-4 = IcoMoonFree:style=Regular:pixelsize=10;1
font-5 = i3fonticon:style=Regular:pixelsize=10;1
font-6 = MaterialIcons:style=Regular:pixelsize=11.5;3
font-7 = IonIcons:style=Medium:pixelsize=10;1
font-8 = NotoSansDisplayNF:style=Regular:pixelsize=11;2

modules-left = bspwm
modules-center =
modules-right = xbacklight pulseaudio wlan date time battery powermenu

cursor-click = pointer
cursor-scroll = ns-resize

separator = "|  "
padding = 2

[module/bspwm]
type = internal/bspwm
format = <label-state> <label-mode>
reverse-scroll = false

ws-icon-0 = term;Ôė≠
ws-icon-1 = chat;Ôė≠
ws-icon-2 = www;Ôė≠
ws-icon-3 = archiver;Ôė≠
ws-icon-4 = code;Ôė≠
ws-icon-5 = media;Ôė≠
ws-icon-6 = discord;Ôė≠
ws-icon-7 = tester;Ôė≠
ws-icon-default = Ôė≠

label-focused = %icon%
label-focused-background = #292D3E
label-focused-foreground = ${colors.palenight_cyan}
label-focused-padding = 2

label-occupied = %icon%
label-occupied-padding = 2

label-urgent = %icon%
label-urgent-background = 292D3E
label-urgent-padding = 2

label-empty = %icon%
label-empty-foreground = #595959
label-empty-padding = 2

label-monocle = Óáģ
label-monocle-padding = 2
label-monocle-background = #292D3E
label-monocle-foreground =  ${colors.palenight_cyan}

label-floating = ÓÄÜ
label-floating-padding = 2
label-floating-background = #292D3E
label-floating-foreground = ${colors.palenight_cyan}

[module/xbacklight]
type = internal/xbacklight

format = <ramp> <label>

label = %percentage:3%%
label-foreground = #fff

ramp-0 = Ô†ī
ramp-foreground = ${colors.dracula_purple}

[module/wlan]
type = internal/network
interface = wlp1s0
interval = 3.0

format-connected = <ramp-signal> <label-connected>
label-connected = %essid%

ramp-signal-0 = Óģĺ
ramp-signal-1 = Óģĺ
ramp-signal-2 = Óģĺ
ramp-signal-3 = Óģĺ
ramp-signal-4 = Óģĺ
ramp-signal-foreground = ${colors.palenight_violet}

[module/pulseaudio]
type = internal/pulseaudio

format-volume = <ramp-volume> <label-volume>
label-volume  = %percentage%%

format-muted = <label-muted>
label-muted  = ÓĪ†
label-muted-foreground = #FFCB6B

ramp-volume-0 = ÓĪ°
ramp-volume-1 = ÓĪě
ramp-volume-2 = ÓĪü
ramp-volume-foreground = ${colors.palenight_yellow}

[module/alsa]
type = internal/alsa

format-volume = <ramp-volume> <label-volume>
label-volume  = %percentage%%

format-muted = <label-muted>
label-muted  = ÓĪ†
label-muted-foreground = #F1FA8C

ramp-volume-0 = ÓĪ°
ramp-volume-1 = ÓĪě
ramp-volume-2 = ÓĪü
ramp-volume-foreground = ${colors.palenight_yellow}

[module/date]
type = internal/date
interval = 5

date = "%d/%m/%Y"
date-alt = "%a Week %V"

time = %H:%M
time-alt = %H:%M

format-prefix = "ÔĀ≥ "
format-prefix-foreground = ${colors.palenight_blue}

label = %date%

[module/time]
type = internal/date
interval = 5

time = %H:%M
format-prefix = "ÓéĄ "
format-prefix-foreground = ${colors.palenight_red}
label = %time%

[module/battery]
type = internal/battery
battery = BAT0
adapter = AC
full-at = 100

format-charging = <animation-charging> <label-charging>

format-discharging = <ramp-capacity> <label-discharging>

format-prefix = "Óįč "

format-prefix-foreground = ${colors.palenight_green}

ramp-capacity-0 = ÓįŹ
ramp-capacity-1 = Óįé
ramp-capacity-2 = Óįć
ramp-capacity-3 = ÓįĆ
ramp-capacity-4 = Óįč
ramp-capacity-foreground = ${colors.palenight_green}

animation-charging-0 = ÓįŹ
animation-charging-1 = Óįé
animation-charging-2 = Óįć
animation-charging-3 = ÓįĆ
animation-charging-4 = Óįč
animation-charging-foreground = ${colors.palenight_green}
animation-charging-framerate = 750

[module/powermenu]
type = custom/menu

expand-right = true

format-spacing = 1

label-open = "ÔÄĎ "
label-open-foreground = ${colors.palenight_beige}
label-close = ÓĀ• cancel
label-close-foreground = ${colors.palenight_beige}
label-separator = |
label-separator-foreground = ${colors.palenight_beige}

menu-0-0 = reboot
menu-0-0-exec = menu-open-1
menu-0-1 = power off
menu-0-1-exec = menu-open-2

menu-1-0 = cancel
menu-1-0-exec = menu-open-0
menu-1-1 = reboot
menu-1-1-exec = sudo reboot

menu-2-0 = power off
menu-2-0-exec = sudo poweroff
menu-2-1 = cancel
menu-2-1-exec = menu-open-0

[settings]
screenchange-reload = true
;compositing-background = xor
;compositing-background = screen
;compositing-foreground = source
;compositing-border = over
;pseudo-transparency = false

